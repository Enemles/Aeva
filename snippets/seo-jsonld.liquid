{%- comment -%}
  SEO JSON-LD structured data.
  Outputs per page_type :
  - index : Organization
  - product : Product + BreadcrumbList
  - collection : BreadcrumbList
{%- endcomment -%}

{%- if request.page_type == 'index' -%}
  {%- liquid
    assign social_csv = ''
    if settings.social_instagram_link != blank
      assign social_csv = social_csv | append: settings.social_instagram_link | append: '|'
    endif
    if settings.social_facebook_link != blank
      assign social_csv = social_csv | append: settings.social_facebook_link | append: '|'
    endif
    if settings.social_pinterest_link != blank
      assign social_csv = social_csv | append: settings.social_pinterest_link | append: '|'
    endif
    if settings.social_tiktok_link != blank
      assign social_csv = social_csv | append: settings.social_tiktok_link | append: '|'
    endif
    if settings.social_youtube_link != blank
      assign social_csv = social_csv | append: settings.social_youtube_link | append: '|'
    endif
  -%}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": {{ shop.name | json }},
    "url": {{ request.origin | json }},
    "description": "Pawly conçoit des produits pour le bien-être de ton animal au quotidien. Jouets intelligents pour chats d'intérieur, accessoires portables pour chiens en rando. Livraison France et Belgique.",
    "email": "contact@gopawly.pro"
    {%- if settings.logo != blank -%}
    , "logo": "https:{{ settings.logo | image_url: width: 400 }}"
    {%- endif -%}
    {%- if social_csv != blank -%}
    , "sameAs": [
      {%- assign social_array = social_csv | split: '|' -%}
      {%- assign output_count = 0 -%}
      {%- for url in social_array -%}
        {%- if url != blank -%}
          {%- if output_count > 0 -%},{% endif -%}
          {{ url | json }}
          {%- assign output_count = output_count | plus: 1 -%}
        {%- endif -%}
      {%- endfor -%}
    ]
    {%- endif -%}
  }
  </script>
{%- endif -%}

{%- if request.page_type == 'product' -%}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Product",
    "name": {{ product.title | json }},
    "description": {{ product.description | strip_html | strip_newlines | truncatewords: 55 | json }},
    "sku": {{ product.selected_or_first_available_variant.sku | default: product.handle | json }},
    "brand": {
      "@type": "Brand",
      "name": "Pawly"
    },
    "image": [
      {%- for image in product.images limit: 6 -%}
        "https:{{ image | image_url: width: 1200 }}"{%- unless forloop.last -%},{%- endunless -%}
      {%- endfor -%}
    ],
    "offers": {
      "@type": "Offer",
      "url": {{ request.origin | append: product.url | json }},
      "priceCurrency": {{ cart.currency.iso_code | json }},
      "price": "{{ product.selected_or_first_available_variant.price | money_without_currency | replace: ',', '.' }}",
      "availability": "{%- if product.available -%}https://schema.org/InStock{%- else -%}https://schema.org/OutOfStock{%- endif -%}",
      "itemCondition": "https://schema.org/NewCondition"
    }
    {%- assign jm_rating_obj = product.metafields.reviews.rating.value -%}
    {%- assign jm_count = product.metafields.reviews.rating_count.value | default: 0 | plus: 0 -%}
    {%- if jm_rating_obj != blank and jm_count > 0 -%}
      {%- assign jm_rating_value = jm_rating_obj.rating | default: jm_rating_obj -%}
      {%- assign jm_rating_max = jm_rating_obj.scale_max | default: 5 -%}
    , "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": "{{ jm_rating_value }}",
      "reviewCount": "{{ jm_count }}",
      "bestRating": "{{ jm_rating_max }}",
      "worstRating": "1"
    }
    {%- endif -%}
  }
  </script>
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Accueil",
        "item": {{ request.origin | json }}
      },
      {
        "@type": "ListItem",
        "position": 2,
        "name": "Boutique",
        "item": "{{ request.origin }}/collections/all"
      },
      {
        "@type": "ListItem",
        "position": 3,
        "name": {{ product.title | json }}
      }
    ]
  }
  </script>
{%- endif -%}

{%- if request.page_type == 'collection' -%}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Accueil",
        "item": {{ request.origin | json }}
      },
      {
        "@type": "ListItem",
        "position": 2,
        "name": {{ collection.title | json }}
      }
    ]
  }
  </script>
{%- endif -%}
